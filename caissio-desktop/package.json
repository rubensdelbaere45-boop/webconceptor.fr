{
  "name": "caissio",
  "version": "1.0.0",
  "description": "Caissio — Logiciel de caisse pour commerçants",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "build": {
    "appId": "fr.webconceptor.caissio",
    "productName": "Caissio",
    "copyright": "© 2026 Caissio",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "main.js",
      "preload.js",
      "resources/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "resources/icon.ico",
      "artifactName": "Caissio-Setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Caissio",
      "license": "resources/license.txt"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns",
      "category": "public.app-category.business",
      "artifactName": "Caissio.dmg"
    },
    "dmg": {
      "title": "Caissio"
    },
    "publish": {
      "provider": "github",
      "owner": "rubensdelbaere45-boop",
      "repo": "webconceptor.fr",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  }
}
