{
  "framework": "nextjs",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/prospect/cron/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/prospect/find/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/prospect/send/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/monitor/n8n/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/gmb/cron/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/audit-ia/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/agentconceptor/posts/cron/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/agentconceptor/devis/[token]/route.ts": {
      "maxDuration": 60
    }
  },
  "regions": ["cdg1"],
  "crons": [
    {
      "path": "/api/prospect/cron",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/prospect/cron",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/monitor/n8n",
      "schedule": "*/15 7-17 * * 1-5"
    },
    {
      "path": "/api/gmb/cron",
      "schedule": "0 7-18 * * 1-6"
    },
    {
      "path": "/api/agentconceptor/posts/cron",
      "schedule": "0 7 * * 1"
    }
  ]
}
