# ── Base ──────────────────────────────────────────────
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_HOST=ton-service.up.railway.app        # à remplacer par l'URL Railway générée
WEBHOOK_URL=https://ton-service.up.railway.app/

# ── Auth (accès à l'interface) ────────────────────────
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-moi-fort    # mot de passe fort ici

# ── Chiffrement workflows ─────────────────────────────
N8N_ENCRYPTION_KEY=change-moi-32-chars-min # openssl rand -hex 32

# ── Base de données PostgreSQL (Railway plugin) ───────
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=${{Postgres.PGHOST}}    # variable Railway auto-injectée
DB_POSTGRESDB_PORT=${{Postgres.PGPORT}}
DB_POSTGRESDB_DATABASE=${{Postgres.PGDATABASE}}
DB_POSTGRESDB_USER=${{Postgres.PGUSER}}
DB_POSTGRESDB_PASSWORD=${{Postgres.PGPASSWORD}}

# ── Exécution ─────────────────────────────────────────
EXECUTIONS_PROCESS=main
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none       # économise de l'espace DB

# ── Timezone ──────────────────────────────────────────
GENERIC_TIMEZONE=Europe/Paris
