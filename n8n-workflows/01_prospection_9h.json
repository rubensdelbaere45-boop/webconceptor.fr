{
  "name": "01 — Prospection quotidienne 9h",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 7 * * 1-5"
            }
          ]
        },
        "timezone": "Europe/Paris"
